# Example Terraform variables for OpenClaw Agents
# Copy this file to ../../terraform.tfvars and customize

# AWS Configuration
aws_region  = "eu-west-2"
environment = "stage"

# Network Configuration
vpc_cidr           = "10.100.0.0/16"
availability_zones = ["eu-west-2a", "eu-west-2b"]

# NAT Gateway (required for Docker image pull and package installation)
enable_nat_gateway        = true
enable_nat_gateway_per_az = false # Set to true for HA (doubles NAT cost)

# Break-glass mode: disable all internet access (requires pre-baked AMI)
break_glass_mode = false

# Logging
cloudwatch_log_retention_days = 30
enable_vpc_flow_logs          = false # Enable for compliance/auditing
enable_kms_encryption         = true

# OpenClaw Configuration
openclaw_default_version     = "2026.2.3" # Pin to specific version (see: https://github.com/openclaw/openclaw/pkgs/container/openclaw)
openclaw_container_registry  = "ghcr.io/openclaw/openclaw"

# Bedrock Configuration
allowed_bedrock_regions = ["eu-west-2", "us-east-1"]

# Agent Definitions
agents = {
  # Research Agent - General purpose LLM tasks
  research-agent = {
    instance_type          = "t3.medium"
    openclaw_version       = "2026.2.3"  # Latest stable
    bedrock_model_id       = "anthropic.claude-3-sonnet-20240229-v1:0"
    enable_marketplace     = false
    detailed_monitoring    = true
    root_volume_size_gb    = 30
    subnet_index           = 0 # eu-west-2a
  }

  # QA Agent - Lightweight testing tasks
  qa-agent = {
    instance_type          = "t3.small"
    openclaw_version       = "2026.2.3"
    bedrock_model_id       = "anthropic.claude-3-haiku-20240307-v1:0"
    enable_marketplace     = false
    detailed_monitoring    = false
    root_volume_size_gb    = 30
    subnet_index           = 1 # eu-west-2b
  }

  # Code Review Agent - Code analysis
  code-review-agent = {
    instance_type          = "t3.large"
    openclaw_version       = "2026.2.3"
    bedrock_model_id       = "anthropic.claude-3-opus-20240229-v1:0"
    enable_marketplace     = false
    detailed_monitoring    = true
    root_volume_size_gb    = 50
    subnet_index           = 0

    # Example: Add custom egress for Git over HTTPS
    custom_security_group_rules = [
      # {
      #   type        = "egress"
      #   from_port   = 9418
      #   to_port     = 9418
      #   protocol    = "tcp"
      #   cidr_blocks = ["0.0.0.0/0"]
      #   description = "Git protocol"
      # }
    ]

    # Example: Attach additional IAM policies
    # additional_iam_policies = [
    #   "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess"
    # ]
  }
}

# Optional: Additional VPC Endpoints
# additional_vpc_endpoint_services = [
#   "ecr.api",      # For pulling from ECR
#   "ecr.dkr",      # For pulling from ECR
#   "sts",          # For AssumeRole
# ]

# Tags
tags = {
  Team       = "Platform"
  CostCenter = "Engineering"
  Compliance = "SOC2"
}

# SSM Session Manager
enable_ssm_session_logging = true

# Restrict SSM access to specific IAM principals (optional)
# allowed_ssm_principals = [
#   "arn:aws:iam::123456789012:role/AdminRole",
#   "arn:aws:iam::123456789012:user/ops-user"
# ]
